AUTH_SECRET="your_auth_secret_here" # Added by `npx auth`. Read more: https://cli.authjs.dev
NEXT_PUBLIC_AUTH_SECRET="your_auth_secret_here"

AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here
AUTH_APPLE_ID="com.your_domain.your_app"
AUTH_APPLE_TEAM_ID="your_apple_team_id_here"
AUTH_APPLE_KEY_ID="your_apple_key_id_here"
# .p8 秘密鍵の中身。改行は \n のまま書く (auth.ts で実際の改行へ変換)
AUTH_APPLE_PRIVATE_KEY="your_apple_private_key_here"

# BFF URL
NEXT_PUBLIC_BFF_URL=https://your-bff-domain.com
# NEXT_PUBLIC_BFF_URL=http://localhost:3000

# AUTH_URL=http://localhost:3000
AUTH_URL=https://your-auth-domain.com
AUTH_TRUST_HOST=true

# AI API keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# free tier keys
GROQ_API_KEY=your_groq_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
DEEPINFRA_API_KEY=your_deepinfra_api_key_here
# Home Server
ARIADNE_API_KEY=your_ariadne_api_key_here


# Vertex AI API keys
GOOGLE_VERTEX_PROJECT=your_google_cloud_project_id_here
GOOGLE_VERTEX_LOCATION=asia-northeast1
GOOGLE_CLIENT_EMAIL=your_client_email@your_google_cloud_project_id_here.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="your_google_private_key_here"

# Google Analytics 4
# GA4 プロパティの測定ID（G-XXXXXXXXXX 形式）
# https://analytics.google.com でプロパティを作成し、データストリームの測定IDをコピー
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# for debug
AI_DEBUG_MODE=true

# リリース通知メール (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
NOTIFY_FROM_EMAIL=noreply@ariadne-ai.app

# 管理者APIシークレット (リリース通知送信など)
ADMIN_API_SECRET=your_admin_secret_here

# RevenueCat Web Billing
# RC ダッシュボード > Project > Apps > Web App で取得
NEXT_PUBLIC_REVENUECAT_WEB_KEY=rcb_pub_your_web_public_key_here
# RC ダッシュボード > Integrations > Webhooks > Authorization Header に入力した値と完全一致させる
REVENUECAT_WEBHOOK_AUTH_HEADER="Bearer your_webhook_secret_here"