{
  "name": "mobile",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "cp src/assets/master-data-production.ts src/assets/master-data.ts && tsc -b && vite build",
    "build:staging": "cp src/assets/master-data-staging.ts src/assets/master-data.ts && tsc -b && vite build --mode staging",
    "lint": "eslint .",
    "preview": "vite preview",
    "ui:add": "npx shadcn@latest add ",
    "reset": "ts-node scripts/reset-app.ts",
    "build:android": "cp src/assets/master-data-production.ts src/assets/master-data.ts && vite build && npx cap sync android",
    "aab": "npm run build:android && cd android && ./gradlew bundleRelease",
    "apk": "npm run build:android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.151",
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor-community/sqlite": "^8.0.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/dialog": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@ionic/react": "^8.8.1",
    "@revenuecat/purchases-capacitor": "^11.3.2",
    "@revenuecat/purchases-capacitor-ui": "^11.3.2",
    "@tailwindcss/vite": "^4.1.14",
    "@uiw/react-json-view": "^2.0.0-alpha.39",
    "ai": "^6.0.149",
    "date-fns-tz": "^3.2.0",
    "embla-carousel-auto-height": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.36.0",
    "i18next": "^26.0.7",
    "idb-keyval": "^6.2.2",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7"
  }
}
