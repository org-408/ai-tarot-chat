# db
DB_USER=aitarot
DB_PASSWORD=yourpassword
DB_NAME=aitarot
DB_HOST=localhost
DB_PORT=5432

VITE_BFF_URL=https://ai-tarot-chat.onrender.com
# VITE_BFF_URL=http://localhost:3000
VITE_DEEP_LINK_SCHEME=aitarotchat

# equals to AUTH_SECRET in web/.env.local
VITE_AUTH_SECRET="yoursecretkeyhere"

# Timezone setting
VITE_LOCAL_TIMEZONE='Asia/Tokyo'

# RevenueCat API Key
VITE_REVENUECAT_IOS_KEY=appl_yourioskeyhere
VITE_REVENUECAT_ANDROID_KEY=goog_yourandroidkeyhere

# Debug menu
VITE_DEBUG_MODE=true

# Legal URLs (displayed in settings page, required for App Store review)
VITE_PRIVACY_POLICY_URL=https://ai-tarot-chat.onrender.com/privacy
VITE_TERMS_URL=https://ai-tarot-chat.onrender.com/terms

# AdMob Ad Unit IDs
# ※ 開発中はGoogleのテスト用IDを使用。本番リリース前に実際のIDに差し替えること。
# iOS
VITE_ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-3940256099942544/4411468910
VITE_ADMOB_IOS_BANNER_ID=ca-app-pub-3940256099942544/2934735716
# Android
VITE_ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-3940256099942544/1033173712
VITE_ADMOB_ANDROID_BANNER_ID=ca-app-pub-3940256099942544/6300978111
